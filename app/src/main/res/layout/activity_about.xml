<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ABOUT"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <ImageView
            android:id="@+id/studentPhoto"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:src="@drawable/min"
            android:scaleType="centerCrop"
            android:layout_marginBottom="15dp"/>
































































        <TextView
            android:id="@+id/txtFullName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Full Name: Nur Syaamin Syaamira Binti Mahmud"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="5dp"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/txtStudentId"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Student ID: 2025137201"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="5dp"
            android:textColor="#000000"/>

        <TextView
            android:id="@+id/txtCourse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Course: ICT602 - Mobile Technology"
            android:textSize="16sp"
            android:textStyle="bold"
            android:padding="10dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="20dp"
            android:textColor="#000000"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="INSTRUCTIONS GUIDE"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="15dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="15dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 1: Use the Spinner dropdown to select the target calendar Month."
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="10dp"
                android:lineSpacingExtra="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 2: Enter the amount of electricity units consumed (restricted to a valid range between 1 and 1000 kWh)"
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="10dp"
                android:lineSpacingExtra="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 3: Slide the rebate bar to apply a cost discount from 0% up to 5% rebate."
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="10dp"
                android:lineSpacingExtra="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 4: Press the 'Calculate and Save' button to compute total charges and insert the record into local database storage."
                android:textSize="14sp"
                android:textColor="#000000"
                android:layout_marginBottom="10dp"
                android:lineSpacingExtra="3dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Step 5: View, update, or remove previous calculations anytime by tapping the 'HISTORY' button."
                android:textSize="14sp"
                android:textColor="#000000"
                android:lineSpacingExtra="3dp"/>

        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="APPLICATION SOURCE CODE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#1976D2"
            android:gravity="center"
            android:layout_marginBottom="10dp"/>

        <TextView
            android:id="@+id/txtGitHubLink"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="GitHub Profile Link"
            android:textSize="14sp"
            android:textColor="#2196F3"
            android:autoLink="web"
            android:linksClickable="true"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/txtCopyright"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2026 Syaamin. All Rights Reserved."
            android:textSize="12sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="BACK"
            android:backgroundTint="#1976D2"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="10dp"/>

    </LinearLayout>
</ScrollView>